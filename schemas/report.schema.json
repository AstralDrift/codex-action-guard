{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AstralDrift/codex-action-guard/schemas/report.schema.json",
  "title": "codex-action-guard JSON report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "root",
    "scanned_files",
    "codex_workflow_files",
    "codex_invocations",
    "findings",
    "safe_patterns",
    "profile_suggestions"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "rule_version", "generated_at"],
      "properties": {
        "tool": { "type": "string" },
        "version": { "type": "string" },
        "rule_version": { "type": "string" },
        "generated_at": { "type": "string" }
      }
    },
    "root": { "type": "string" },
    "scanned_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "codex_workflow_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "codex_invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "job", "kind", "privilege_context"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "number" },
          "job": { "type": "string" },
          "step": { "type": "string" },
          "kind": { "type": "string" },
          "prompt_boundary": { "type": "string" },
          "prompt_file": { "type": "string" },
          "output_file": { "type": "string" },
          "output_schema_file": { "type": "string" },
          "sandbox": { "type": "string" },
          "safety_strategy": { "type": "string" },
          "privilege_context": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "title",
          "severity",
          "confidence",
          "file",
          "privilege_context",
          "evidence",
          "why_it_matters",
          "safer_pattern",
          "false_positive_notes",
          "references"
        ],
        "properties": {
          "rule_id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "file": { "type": "string" },
          "line": { "type": "number" },
          "source": { "type": "string" },
          "prompt_boundary": { "type": "string" },
          "codex_invocation": { "type": "string" },
          "privilege_context": { "type": "string" },
          "downstream_sink": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file", "description"],
              "properties": {
                "file": { "type": "string" },
                "line": { "type": "number" },
                "description": { "type": "string" },
                "snippet": { "type": "string" }
              }
            }
          },
          "why_it_matters": { "type": "string" },
          "safer_pattern": { "type": "string" },
          "false_positive_notes": { "type": "string" },
          "references": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "safe_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "pattern"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "number" },
          "pattern": { "type": "string" }
        }
      }
    },
    "profile_suggestions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
